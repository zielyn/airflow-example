#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$ROOT_DIR/docker/docker-compose-local.yml"
RESET_FILE="$ROOT_DIR/docker/docker-compose-resetdb.yml"
TEST_FILE="$ROOT_DIR/docker/docker-compose-test.yml"
ENV_FILE="$ROOT_DIR/.env"

display_help() {
  cat <<'EOF'
MWAA-like local runner

Commands:
  help                 Show this help
  init-env             Create .env from .env.example if missing
  validate-prereqs     Validate docker, docker compose, python3, and pip3
  build-image          Build the local MWAA Airflow image from subtree sources
  start                Start the local Airflow stack
  stop                 Stop the local Airflow stack
  reset-db             Reset the metadata database
  test-requirements    Validate requirements installation in an ephemeral run
  test-startup-script  Execute the startup script in an ephemeral run
  open-shell           Open a shell in the airflow container image
EOF
}

require_command() {
  local command_name="$1"
  if command -v "$command_name" >/dev/null 2>&1; then
    printf '%s\n' "$command_name: ok"
  else
    printf '%s\n' "$command_name: missing"
    return 1
  fi
}

ensure_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    cp "$ROOT_DIR/.env.example" "$ENV_FILE"
    printf '%s\n' "Created $ENV_FILE from .env.example"
  fi
}

compose() {
  ensure_env
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

reset_compose() {
  ensure_env
  docker compose --env-file "$ENV_FILE" -f "$RESET_FILE" "$@"
}

test_compose() {
  ensure_env
  docker compose --env-file "$ENV_FILE" -f "$TEST_FILE" "$@"
}

build_mwaa_image() {
  ensure_env

  # shellcheck disable=SC1090
  source "$ENV_FILE"

  local airflow_version="${AIRFLOW_VERSION:-3.0.6}"
  local image_dir="$ROOT_DIR/st/amazon-mwaa-docker-images/images/airflow/${airflow_version}"
  local repo="${MWAA_IMAGE_REPOSITORY:-amazon-mwaa-docker-images/airflow}"

  if [[ ! -d "$image_dir" ]]; then
    printf '%s\n' "Unsupported or missing MWAA version directory: $image_dir"
    return 1
  fi

  docker build \
    -f "$image_dir/Dockerfiles/Dockerfile.base" \
    -t "$repo:${airflow_version}-base" \
    "$image_dir"

  docker build \
    -f "$image_dir/Dockerfiles/Dockerfile-dev" \
    -t "$repo:${airflow_version}-dev" \
    "$image_dir"
}

case "${1:-help}" in
  help)
    display_help
    ;;
  init-env)
    ensure_env
    ;;
  validate-prereqs)
    require_command docker
    docker compose version >/dev/null 2>&1 && printf '%s\n' 'docker compose: ok' || { printf '%s\n' 'docker compose: missing'; exit 1; }
    ;;
  build-image)
    build_mwaa_image
    ;;
  start)
    compose up -d
    ;;
  stop)
    compose down --remove-orphans
    ;;
  reset-db)
    reset_compose up --abort-on-container-exit --exit-code-from resetdb resetdb
    ;;
  test-requirements)
    test_compose up --abort-on-container-exit --exit-code-from test-requirements test-requirements
    ;;
  test-startup-script)
    test_compose up --abort-on-container-exit --exit-code-from test-startup-script test-startup-script
    ;;
  open-shell)
    compose run --rm webserver shell
    ;;
  *)
    display_help
    exit 1
    ;;
esac
