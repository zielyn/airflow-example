COMPOSE_PROJECT_NAME=airflow-example
AIRFLOW_VERSION=3.0.6
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=test
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_LOAD_EXAMPLES=False
AIRFLOW_API_PORT=8080
AIRFLOW_FERNET_KEY=

# Optional AWS credentials for local testing. Leave empty to use your existing
# AWS CLI/SDK configuration inside WSL or the devcontainer.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2
